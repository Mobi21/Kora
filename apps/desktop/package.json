{
  "name": "@kora/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "wait-on tcp:5173 && ELECTRON_RUN_AS_NODE= electron .",
    "dev:all": "concurrently -n vite,electron -c blue,magenta \"npm:dev\" \"npm:dev:electron\"",
    "build": "tsc -b && vite build && electron-builder",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('node:fs').writeFileSync('dist-electron/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "build:icons": "bash build/generate-icons.sh",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "5.2.5",
    "@fontsource-variable/inter": "5.2.5",
    "@fontsource-variable/jetbrains-mono": "5.2.5",
    "@fullcalendar/core": "6.1.15",
    "@fullcalendar/daygrid": "6.1.15",
    "@fullcalendar/interaction": "6.1.15",
    "@fullcalendar/list": "6.1.15",
    "@fullcalendar/react": "6.1.15",
    "@fullcalendar/timegrid": "6.1.15",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-tooltip": "1.1.8",
    "@tanstack/react-query": "^5.66.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.0.4",
    "framer-motion": "11.18.2",
    "lucide-react": "0.474.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "7.1.5",
    "tailwind-merge": "2.6.0",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "22.13.1",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "9.1.2",
    "electron": "34.1.1",
    "electron-builder": "25.1.8",
    "eslint": "9.19.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.18",
    "prettier": "3.4.2",
    "tailwindcss": "^4.2.4",
    "typescript": "5.7.3",
    "typescript-eslint": "8.23.0",
    "vite": "6.1.0",
    "vitest": "3.0.5",
    "wait-on": "8.0.2"
  }
}

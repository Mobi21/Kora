# Kora Environment Configuration
# ================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Machine-specific overrides go in .env.local (gitignored).
# .env.local values take precedence over .env.


# =============================================================================
# REQUIRED — Kora won't start without this
# =============================================================================

# MiniMax API key (primary LLM provider)
MINIMAX_API_KEY=your_minimax_api_key_here


# =============================================================================
# MINIMAX LLM (Primary Provider)
# =============================================================================

MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TEMPERATURE=0.7
MINIMAX_CONTEXT_WINDOW=205000
MINIMAX_MAX_OUTPUT_TOKENS=16384
MINIMAX_TIMEOUT=120
MINIMAX_MAX_RETRIES=3
MINIMAX_INITIAL_BACKOFF=1.0
MINIMAX_BACKOFF_MULTIPLIER=2.0

# Provider selection: "minimax" (default) or "gemini" (legacy fallback)
ACTIVE_PROVIDER=minimax
# FALLBACK_PROVIDER=gemini


# =============================================================================
# GEMINI LLM (Legacy — optional fallback)
# =============================================================================
# Only needed if FALLBACK_PROVIDER=gemini or ACTIVE_PROVIDER=gemini

# Google Gemini API key - free at https://aistudio.google.com/apikey
#GEMINI_API_KEY=your_gemini_api_key_here
#GEMINI_MODEL=gemini-3-flash-preview
#GEMINI_TEMPERATURE=1.0
#GEMINI_DEFAULT_THINKING_LEVEL=medium
#GEMINI_CONTEXT_WINDOW=1000000
#GEMINI_MAX_OUTPUT_TOKENS=65536
#GEMINI_ENABLE_CONTEXT_CACHING=true
#GEMINI_TOP_P=0.9
#GEMINI_TIMEOUT=120
#GEMINI_MAX_RETRIES=3
#GEMINI_INITIAL_BACKOFF=1.0
#GEMINI_BACKOFF_MULTIPLIER=2.0


# =============================================================================
# EMBEDDING MODEL
# =============================================================================
# Default: nomic-embed-text-v1.5 (local, 768 dim, ~550MB VRAM)
EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=100
EMBEDDING_MAX_SEQ_LENGTH=2048
EMBEDDING_QUEUE_PROCESS_INTERVAL=0.5
EMBEDDING_USE_GPU=true


# =============================================================================
# DATABASE
# =============================================================================

DB_SQLITE_PATH=data/kora.db
DB_CHROMA_PATH=data/chroma
DB_WAL_MODE=true


# =============================================================================
# MEMORY SYSTEM
# =============================================================================

# Character limits per memory layer (3 layers: working, episodic, reflective)
MEMORY_WORKING_CHAR_LIMIT=2000
MEMORY_EPISODIC_CHAR_LIMIT=8000
MEMORY_REFLECTIVE_CHAR_LIMIT=20000

# Extraction
MEMORY_UPDATE_EXTRACTION_TEMPERATURE=0.1
MEMORY_UPDATE_DECISION_TEMPERATURE=0.1
MEMORY_UPDATE_SEMANTIC_SIMILARITY_THRESHOLD=0.85
MEMORY_UPDATE_MAX_SIMILAR_MEMORIES=5
MEMORY_UPDATE_ENABLE_PARALLEL_EXTRACTION=true
MEMORY_UPDATE_STORE_CONTENT_HASH=true
MEMORY_UPDATE_MAX_EXTRACTIONS_PER_TURN=10
MEMORY_UPDATE_MIN_EXTRACTION_CONFIDENCE=0.5
MEMORY_UPDATE_EXTRACTION_TIMEOUT=30.0

# Deduplication
MEMORY_UPDATE_DEDUP_SIMILARITY_THRESHOLD=0.65
MEMORY_UPDATE_MAX_QUEUE_BATCH_SIZE=5


# =============================================================================
# CONSOLIDATION (idle-time memory maintenance)
# =============================================================================

CONSOLIDATION_SELF_SCAN_INTERVAL_TURNS=10
CONSOLIDATION_AWARENESS_DETAIL_LEVEL=summary
CONSOLIDATION_MAX_MEMORIES_PER_REFLECTION=50
CONSOLIDATION_REFLECTION_TIMEOUT_MINUTES=10
CONSOLIDATION_GIST_AGE_THRESHOLD_DAYS=180
CONSOLIDATION_GIST_MAX_CHARS=4000
CONSOLIDATION_DEDUP_SIMILARITY_THRESHOLD=0.85
CONSOLIDATION_MAX_SIMILARITY_CLUSTER_SIZE=10
CONSOLIDATION_EMOTIONAL_WEIGHT_THRESHOLD=0.7
CONSOLIDATION_REASONING_TEMPERATURE=0.3
CONSOLIDATION_CONSOLIDATION_TEMPERATURE=0.1
CONSOLIDATION_CONSOLIDATION_TIMEOUT=60.0
CONSOLIDATION_SUGGEST_REFLECTION_AFTER_CLUSTERS=5
CONSOLIDATION_SUGGEST_REFLECTION_AFTER_OLD_MEMORIES=20


# =============================================================================
# SYNTHESIS (response generation pipeline)
# =============================================================================

SYNTHESIS_CONTEXT_BUDGET=8000
SYNTHESIS_MIN_EMOTION_BUDGET=200
SYNTHESIS_MIN_PERSONALITY_BUDGET=300
SYNTHESIS_MIN_HISTORY_BUDGET=500
SYNTHESIS_MIN_MEMORY_BUDGET=500
SYNTHESIS_REASONING_TEMPERATURE=0.3
SYNTHESIS_SYNTHESIS_TEMPERATURE=0.2
SYNTHESIS_REASONING_MAX_TOKENS=512
SYNTHESIS_SYNTHESIS_MAX_TOKENS=1024


# =============================================================================
# CONTINUITY (session management, summarization)
# =============================================================================

CONTINUITY_SOFT_THRESHOLD_PCT=0.70
CONTINUITY_HARD_THRESHOLD_PCT=0.85
CONTINUITY_CONTEXT_WINDOW_TOKENS=32768
CONTINUITY_CHARS_PER_TOKEN_ESTIMATE=4.0
CONTINUITY_MAX_BRIDGES_PER_CONVERSATION=3
CONTINUITY_IDLE_TIMEOUT_MINUTES=15
CONTINUITY_IDLE_WARNING_MINUTES=12
CONTINUITY_SNAPSHOT_TEMPERATURE=0.1
CONTINUITY_MAX_SNAPSHOT_CHARS=4000
CONTINUITY_LAST_MESSAGES_TO_KEEP=5
CONTINUITY_SNAPSHOT_TIMEOUT=30.0
CONTINUITY_SUMMARIZATION_SOFT_THRESHOLD_PCT=0.70
CONTINUITY_SUMMARIZATION_HARD_THRESHOLD_PCT=0.85
CONTINUITY_SUMMARIZATION_KEEP_TURNS=3
CONTINUITY_SUMMARIZATION_TEMPERATURE=0.1
CONTINUITY_SUMMARIZATION_MAX_CHARS=2000
CONTINUITY_SUMMARIZATION_TIMEOUT=30.0
CONTINUITY_DIGESTION_TEMPERATURE=0.1
CONTINUITY_DIGESTION_TIMEOUT=60.0


# =============================================================================
# EVENT SYSTEM
# =============================================================================

EVENT_ENABLE_PERSISTENCE=true
EVENT_RETENTION_DAYS=30
EVENT_BATCH_SIZE=100
EVENT_FLUSH_INTERVAL_SECONDS=5.0
EVENT_MAX_EVENTS_PER_SESSION=10000
EVENT_ENABLE_METRICS=true
EVENT_METRICS_WINDOW_SIZE=1000
EVENT_ENABLE_SELF_AWARENESS=true
EVENT_REFLECTION_BUFFER_SIZE=500
EVENT_ENABLE_LOGGING_MIDDLEWARE=true
EVENT_LOG_LEVEL=debug
EVENT_ENABLE_TIMING_MIDDLEWARE=true
EVENT_KEEP_HISTORY=true
EVENT_MAX_HISTORY=1000


# =============================================================================
# TOOL SYSTEM
# =============================================================================

## MAX_TOOL_CALLS_PER_TURN was removed. Guardrails now rely on loop time, error streaks,
## and consecutive same-tool detection rather than a total-call cap.
MAX_CONSECUTIVE_TOOL_ERRORS=5
MAX_TOOL_LOOP_SECONDS=300
MAX_CONSECUTIVE_SAME_TOOL_SOFT=15
MAX_CONSECUTIVE_SAME_TOOL_HARD=25
MCP_SERVERS_PATH=kora/config/mcp_servers.yaml


# =============================================================================
# SUBAGENT SYSTEM
# =============================================================================

SUBAGENT_ENABLED=true
SUBAGENT_MAX_CONCURRENT=3
SUBAGENT_DEFAULT_TIMEOUT=90
SUBAGENT_DEFAULT_THINKING_LEVEL=medium
SUBAGENT_DEFAULT_MAX_TOOL_CALLS=20
SUBAGENT_ENABLE_PARALLEL_DELEGATION=true
SUBAGENT_RESOURCE_CHECK_ENABLED=true


# =============================================================================
# DAEMON (always-on mode, system tray, idle processing)
# =============================================================================

# Hotkey: win+shift+k (Windows) or cmd+shift+k (macOS). Leave unset for auto-detect.
# DAEMON_HOTKEY=cmd+shift+k
DAEMON_TRAY_ENABLED=true
DAEMON_AUTOSTART=false
DAEMON_LOCKFILE_PATH=data/kora.lock
# Terminal: wt (Windows), auto (macOS auto-detect iTerm2/Terminal.app). Leave unset for auto-detect.
# DAEMON_TERMINAL_COMMAND=auto
DAEMON_ICON_UPDATE_INTERVAL=30
DAEMON_IPC_HOST=127.0.0.1
DAEMON_IPC_PORT=0
DAEMON_RESOURCE_CHECK_INTERVAL=60

# Idle mode
DAEMON_IDLE_ENABLED=true
DAEMON_IDLE_DEFAULT_SLEEP=300
DAEMON_IDLE_MIN_SLEEP=30
DAEMON_IDLE_MAX_SLEEP=600
DAEMON_IDLE_CPU_THRESHOLD=70.0
DAEMON_IDLE_MEMORY_THRESHOLD=85.0
DAEMON_IDLE_MAX_WORK_ITEMS_PER_CYCLE=5
DAEMON_GREETING_MAX_TOKENS=300

# Lifecycle
DAEMON_LIFECYCLE_ENABLED=true
DAEMON_PRESENCE_IDLE_TIMEOUT=600

# Quiet hours (no notifications between these hours)
DAEMON_NOTIFICATION_QUIET_START=22
DAEMON_NOTIFICATION_QUIET_END=8

# Daily planning
DAEMON_PLANNING_ENABLED=true
DAEMON_PLANNING_HOUR=6
DAEMON_DAILY_WORK_BUDGET_MINUTES=240
DAEMON_MAX_REPLANS_PER_DAY=5
DAEMON_MORNING_PLAN_HOUR=8
DAEMON_EVENING_REVIEW_HOUR=21

# Weekly reflection
DAEMON_WEEKLY_REFLECTION_DAY=6
DAEMON_WEEKLY_REFLECTION_HOUR=18

# Proactive engagement
DAEMON_PROACTIVE_COOLDOWN=3600
DAEMON_MAX_PROACTIVE_PER_DAY=5

# Observability API
DAEMON_API_ENABLED=true
DAEMON_API_HOST=127.0.0.1
DAEMON_API_PORT=7433
DAEMON_API_TOKEN=


# =============================================================================
# APPLICATION
# =============================================================================

APP_NAME=Kora
DEBUG=false
LOG_LEVEL=INFO
DATA_DIR=data


# =============================================================================
# MCP SERVER API KEYS
# =============================================================================
# Used by MCP servers in kora/config/mcp_servers.yaml.
# Set keys here OR in the yaml env: section.
# See Documentation/how-to/06_mcp_setup_guide.md for full setup instructions.
#
# Uncomment and fill in as you set up each server.

# --- Tier 1: World Awareness ---
# Brave Search - free at https://brave.com/search/api/
BRAVE_API_KEY=
# OpenWeatherMap - free at https://openweathermap.org/api
#OPENWEATHER_API_KEY=

# --- Tier 2: Daily Life ---
# Google OAuth credentials JSON (covers Calendar + Gmail + Drive)
# Setup: https://console.cloud.google.com/ — enable Calendar, Gmail, Drive APIs
#GOOGLE_OAUTH_CREDENTIALS=/path/to/google-oauth-credentials.json
# Obsidian Local REST API (Obsidian > Settings > Community Plugins > Local REST API)
#OBSIDIAN_API_KEY=
#OBSIDIAN_BASE_URL=http://127.0.0.1:27123
#OBSIDIAN_VERIFY_SSL=false
# Notion - free at https://www.notion.so/my-integrations
#NOTION_TOKEN=

# --- Tier 3: Personality ---
# Spotify - free at https://developer.spotify.com/dashboard
#SPOTIFY_CLIENT_ID=
#SPOTIFY_CLIENT_SECRET=
# TMDB - free API key at https://www.themoviedb.org/settings/api
#TMDB_AUTH_TOKEN=

# --- Tier 4: Smart Home ---
# Home Assistant - Docker on same PC, token: HA > Profile > Long-Lived Access Tokens
#HASS_HOST=http://localhost:8123
#HASS_TOKEN=
#HASS_SOCKET_URL=ws://localhost:8123/api/websocket

# --- Tier 5: Communication ---
# Twilio SMS/WhatsApp - https://www.twilio.com/ - $15 free trial
#TWILIO_ACCOUNT_SID=
#TWILIO_API_KEY=
#TWILIO_API_SECRET=

# --- Tier 6: Development ---
# GitHub PAT - free at https://github.com/settings/tokens
# Fine-grained: Contents (R/W), Metadata (R), Pull requests (R/W), Issues (R/W)
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Tier 7: Creative & Social ---
# Nanobana image gen - uses Gemini key or OpenRouter at https://openrouter.ai/
#MODEL_API_KEY=
# Twitter/X - https://developer.twitter.com/
#API_KEY=
#API_SECRET_KEY=
#ACCESS_TOKEN=
#ACCESS_TOKEN_SECRET=
# Reddit - https://www.reddit.com/prefs/apps - select "script" type
#REDDIT_CLIENT_ID=
#REDDIT_CLIENT_SECRET=
#REDDIT_USERNAME=
#REDDIT_PASSWORD=
#REDDIT_USER_AGENT=kora-companion/1.0.0


# =============================================================================
# PHASE 9 — CAPABILITY PACKS
# =============================================================================

# --- Google Workspace MCP server ---
# Command and args used to launch the external Google Workspace MCP server.
# Recommended: https://github.com/taylorwilsdon/google_workspace_mcp
# Run with: uvx google-workspace-mcp
#KORA_MCP__SERVERS__workspace__COMMAND=uvx
#KORA_MCP__SERVERS__workspace__ARGS=["google-workspace-mcp"]

# --- agent-browser ---
# Absolute path to the agent-browser binary.
# If agent-browser is on PATH and named "agent-browser", this can be omitted.
#KORA_BROWSER__BINARY_PATH=/path/to/agent-browser

# --- Obsidian vault ---
# Path to your Obsidian vault root. Kora writes clips to Clips/ inside this path.
# If unset, vault features are disabled (non-fatal).
#KORA_VAULT__PATH=~/ObsidianVault
